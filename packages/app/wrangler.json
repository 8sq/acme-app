{
  "name": "acme",
  "compatibility_date": "2026-03-01",
  "compatibility_flags": ["nodejs_compat"],
  "pages_build_output_dir": "dist",
  "dev": {
    "ip": "0.0.0.0"
  },
  "kv_namespaces": [
    {
      "binding": "CACHE",
      "id": "00000000000000000000000000000000"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "dev",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "db/migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "STORAGE_PUBLIC",
      "bucket_name": "acme-public",
      "preview_bucket_name": "acme-public-preview"
    },
    {
      "binding": "STORAGE_PRIVATE",
      "bucket_name": "acme-private",
      "preview_bucket_name": "acme-private-preview"
    }
  ]
}
